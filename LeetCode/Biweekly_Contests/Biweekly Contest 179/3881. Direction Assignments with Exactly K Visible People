class Solution {
     int M=1_000_000_007;
    long []factorial,fact;
    public int countVisiblePeople(int n, int pos, int k) 
    {
        if(k>n-1)
            return 0;
        compute(n);
        long ans=nr(n-1,k);
        ans=(ans*2)%M;
        return (int) ans;
    }
     void compute(int n) {
        factorial= new long[n + 1];
        fact = new long[n + 1];
        factorial[0] = 1;
        for (int i = 1; i <= n; i++) {
            factorial[i] = factorial[i - 1] * i % M;
        }

        fact[n] = power(factorial[n],M- 2);
        for (int i = n - 1; i >= 0; i--) {
            fact[i] = fact[i + 1] * (i + 1) % M;
        }
    }
    long nr(int n, int r) {
        if (r < 0 || r > n) return 0;
        return factorial[n] *fact[r] % M*fact[n - r] %M;
    }
    long power(long x, long y) {
        long res = 1;
        while (y > 0) {
            if ((y & 1) == 1) {
                res = res * x % M;
            }
            x = x * x % M;
            y >>= 1;
        }
        return res;
}}
