class Solution {
    public int minAbsoluteDifference(int[] nums) {
        int flag = 0;
        int mindif = Integer.MAX_VALUE;
        for (int i =0; i<nums.length;i++) {
            for (int j =i+1; j<nums.length;j++) {
                if ((nums[i]== &&nums[j]==2) || nums[j]==1&&nums[i]==2)) {
                    flag = 1;
                    mindif = Math.min(mindif, Math.abs(j - i));
                }
        }
        if (flag==0)
            return -1;
        return mindif;
}}
