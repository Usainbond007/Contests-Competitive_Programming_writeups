class Solution {
    public int minOperations(int[] nums) 
    {
     int ops=0;
      for(int i=0;i<nums.length;i++) 
          {
              if((i&1)==1)
              {
                  if(isprime(nums[i]))
                  {
                      if(nums[i]==2)
                          ops=ops+2;
                      else
                          ops++;
                  }
              }
              else
              {
                  if(!isprime(nums[i]))
                  {
                      int temp=nums[i];
                      while(true)
                          {
                              temp=temp+1;
                              ops++;
                              if(isprime(temp))
                                  break;
                          }
                  }
              }
          }
        return ops;
    }
    public boolean isprime(int n)
    {
    if (n<=1) return false;        
    if (n ==2) return true;        
    if (n % 2 == 0) return false;   
    for (int i = 3; i * i <= n;i+=2) {
        if (n % i==0) return false;
    }
    return true;
}
}
/* 
    Essentially the caveat is that even indices- has to be prime
    odd indices- has to be non prime
    so we just check boundary conditions for that
    if its non prime in even index - we can keep adding one greedily and increment ops and then simultaneously check that its satisfying prime property
   inversely if its prime in odd index- we add 1 for all numbers except 2- if its 2 add 2
   thats pretty much it :)

*/
