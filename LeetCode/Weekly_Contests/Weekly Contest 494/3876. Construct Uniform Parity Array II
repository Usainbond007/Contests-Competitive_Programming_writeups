class Solution {
    public boolean uniformArray(int[] nums1)
    {
        if(nums1.length==1)
            return true;
        boolean odd=false;
 
        boolean even=false;
        for(int i=0;i<nums1.length;i++)
            {
                if(nums1[i]%2==0)
                {
                    even=true;
                }
                else
                {
                  odd=true;
                }
            }
   int min=Integer.MAX_VALUE;
        for(int i=0;i<nums1.length;i++)
            {
                min=Math.min(nums1[i],min);
            }
        
        if(odd&&!even)
        {
            return true;
        }
        if(even&&!odd)
            return true;
            if(min%2==0)
                return false;
            else
                return true;
    }
}
